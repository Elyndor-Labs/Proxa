PORT=3001
RPC_URL=https://api.devnet.solana.com
PROXA_NETWORK=devnet
# Local path, Render secret-file path, or raw JSON byte array.
KEEPER_KEYPAIR=~/.config/solana/id.json
# Alternative for deploy hosts where a separate JSON env var is easier.
KEEPER_KEYPAIR_JSON=
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
ADMIN_API_KEY=
TXODDS_API_BASE=
TXODDS_GUEST_JWT=
TXODDS_API_KEY=
